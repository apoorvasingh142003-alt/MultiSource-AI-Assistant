# ─────────────────────────────────────────────────────────────────────────────
# AI Business Knowledge Assistant — configuration
# Copy to `.env` and fill in. Everything has a sensible default; the only thing
# you need for LIVE answers is an API key. Without it, the demo still runs in
# OFFLINE mode using deterministic answers for the example questions.
# ─────────────────────────────────────────────────────────────────────────────

# --- LLM provider -------------------------------------------------------------
# "anthropic" (Claude) or "openai" (ANY OpenAI-compatible endpoint: OpenAI, Groq,
# Gemini compat, Ollama, OpenRouter…). The engine is provider-agnostic; pick one.
ABA_LLM_PROVIDER=anthropic

# Offline demo mode: "auto" (use cache/deterministic when no key or on error),
# "always" (never call an LLM — $0), "never" (always call).
ABA_OFFLINE_MODE=auto

# Cache-first: replay an identical prior question from cache instantly (snappy demos).
# New questions still go live. Set false to always call the model.
ABA_CACHE_FIRST=true

# ── Option A — Anthropic Claude (paid, best quality) ──────────────────────────
ANTHROPIC_API_KEY=
ABA_MODEL_GENERATION=claude-opus-4-8
ABA_MODEL_ROUTER=claude-sonnet-4-6
ABA_MODEL_SQL=claude-sonnet-4-6

# ── Option B — OpenAI-compatible (set ABA_LLM_PROVIDER=openai) ────────────────
# OPENAI_API_KEY and ABA_OPENAI_BASE_URL select the actual provider. Examples:
#
#   FREE · Groq (fast, no card)        https://console.groq.com/keys
#     ABA_LLM_PROVIDER=openai
#     OPENAI_API_KEY=gsk_...
#     ABA_OPENAI_BASE_URL=https://api.groq.com/openai/v1
#     ABA_MODEL_GENERATION=llama-3.3-70b-versatile
#     ABA_MODEL_ROUTER=llama-3.1-8b-instant
#     ABA_MODEL_SQL=llama-3.1-8b-instant
#
#   FREE · Google Gemini (best multilingual)   https://aistudio.google.com/apikey
#     ABA_LLM_PROVIDER=openai
#     OPENAI_API_KEY=AIza...
#     ABA_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#     ABA_MODEL_GENERATION=gemini-2.0-flash
#     ABA_MODEL_ROUTER=gemini-2.0-flash
#     ABA_MODEL_SQL=gemini-2.0-flash
#
#   FREE · Ollama (fully local, no key)   https://ollama.com  (run `ollama serve`)
#     ABA_LLM_PROVIDER=openai
#     ABA_OPENAI_BASE_URL=http://localhost:11434/v1
#     ABA_MODEL_GENERATION=llama3.1
#     ABA_MODEL_ROUTER=llama3.1
#     ABA_MODEL_SQL=llama3.1
#
#   PAID · OpenAI                         https://platform.openai.com/api-keys
#     ABA_LLM_PROVIDER=openai
#     OPENAI_API_KEY=sk-...
#     ABA_OPENAI_BASE_URL=https://api.openai.com/v1
#     ABA_MODEL_GENERATION=gpt-4o
#     ABA_MODEL_ROUTER=gpt-4o-mini
#     ABA_MODEL_SQL=gpt-4o-mini
#
OPENAI_API_KEY=
ABA_OPENAI_BASE_URL=https://api.openai.com/v1

# --- Embeddings (multilingual) ------------------------------------------------
# backend: "auto" → OpenAI embeddings when provider=openai on api.openai.com (cheap,
# high quality, multilingual); else a local sentence-transformers model; else a
# deterministic hashing fallback (no deps, reproducible). Force with openai/local/hashing.
ABA_EMBEDDING_BACKEND=auto
ABA_OPENAI_EMBED_MODEL=text-embedding-3-small
ABA_EMBEDDING_MODEL=BAAI/bge-m3
ABA_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
ABA_ENABLE_RERANK=true

# --- Vector store -------------------------------------------------------------
# "numpy" (in-process, zero-dependency, default) or "qdrant" (docker-compose service).
ABA_VECTOR_BACKEND=numpy
ABA_QDRANT_URL=http://qdrant:6333

# --- Retrieval tuning ---------------------------------------------------------
ABA_DENSE_TOP_K=20
ABA_BM25_TOP_K=20
ABA_RRF_K=60
ABA_FINAL_K=5
ABA_RERANK_TOP_N=20
ABA_MIN_EVIDENCE_SCORE=0.02

# --- SQL safety ---------------------------------------------------------------
ABA_SQL_ROW_LIMIT=200
ABA_SQL_TIMEOUT_SECONDS=5

# --- Paths --------------------------------------------------------------------
ABA_DATA_DIR=data
