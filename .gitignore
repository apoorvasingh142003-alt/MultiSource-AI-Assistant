# Python
.venv/
__pycache__/
*.pyc
*.egg-info/

# Secrets / env
.env
.env.local

# LLM response cache (machine-specific). The demo data (data/business.db, data/pdfs/*)
# IS committed so the repo is instantly runnable and the PDFs are browsable on GitHub;
# regenerate any time with scripts/seed_data.py + scripts/make_pdfs.py.
data/cache/

# Runtime customer uploads (PDFs / SQLite) + the merged working DB — session-scoped, never committed.
data/uploads/

# Node / Next
ui/node_modules/
ui/.next/
ui/out/
ui/tsconfig.tsbuildinfo

# Personal / client documents kept out of the public repo (privacy). The sample
# contract PDFs under data/pdfs/ ARE committed; these real uploads are not.
/Apoorv-Pandey-*.pdf
/IMM_Prototype_Scope_and_Valuation.pdf

# OS / editor
.DS_Store
*.log

# Working notes stay local — publish only the overview, architecture, and screenshots.
context.md
/docs/*
!/docs/architecture.md
!/docs/overview.md
!/docs/AI_Business_Assistant_Overview.pdf
!/docs/images/
